# Backend runtime configuration
PORT=8080
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
MONGO_URI_SECRET_NAME=mongo-uri
JWT_SECRET_SECRET_NAME=jwt-secret

# Recommended for Cloud Run once the frontend URL is known.
CORS_ORIGIN=http://localhost:8081

# Optional values used by specific features.
BASE_URL=http://localhost:3000
ML_SERVICE_URL=http://localhost:5001
ANALYTICS_SERVICE_URL=http://localhost:5002
EMAIL=
PASS=

# Optional local-only overrides. If these are set, the backend skips Secret Manager for them.
# MONGO_URI=
# JWT_SECRET=
# UPLOAD_DIR=/tmp/uploads
