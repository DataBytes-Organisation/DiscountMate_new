project_id = "your-gcp-project-id"
region     = "australia-southeast1"

# Set to a multi-region like AU if preferred.
bucket_location      = "AU"
bucket_storage_class = "STANDARD"

artifact_registry_repository_id                      = "discount-mate-images"
artifact_registry_cleanup_delete_untagged_older_than = "30d"
artifact_registry_cleanup_dry_run                    = false

github_actions_service_account_id = "github-actions-prod"
backend_service_name              = "webdev-backend"
backend_container_image           = "australia-southeast1-docker.pkg.dev/sit-26t1-discountmate-935cb94/discount-mate-images/webdev-backend:latest"
backend_min_instance_count        = 0
backend_max_instance_count        = 2
backend_mongo_secret_name         = "webdev-backend-mongo-uri"
backend_jwt_secret_name           = "webdev-backend-jwt-secret"
mongo_uri                         = "mongodb+srv://username:password@cluster.example.mongodb.net/discountmate"
jwt_secret                        = "replace-with-a-strong-random-secret"

base_url = null

postgres_instance_name    = "discount-mate-prod-postgres"
postgres_database_version = "POSTGRES_16"
postgres_tier             = "db-f1-micro"
postgres_disk_size_gb     = 10
postgres_database_name    = "discount_mate_db"
postgres_user_name        = "discount_mate_pguser"
postgres_user_password    = "replace-with-a-strong-password"
postgres_authorized_networks = [
  {
    name       = "au-office-1"
    cidr_block = "203.0.113.10/32"
  },
  {
    name       = "au-vpn"
    cidr_block = "198.51.100.0/24"
  },
]

default_labels = {
  application = "discount-mate"
  owner       = "platform"
}
